{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:4173/",
        "http://127.0.0.1:4173/about",
        "http://127.0.0.1:4173/models",
        "http://127.0.0.1:4173/models/sonnet-4-7",
        "http://127.0.0.1:4173/runs",
        "http://127.0.0.1:4173/runs/run-0000",
        "http://127.0.0.1:4173/runs/run-0000/transcripts/CG-AL-E001/1",
        "http://127.0.0.1:4173/families",
        "http://127.0.0.1:4173/families/claude",
        "http://127.0.0.1:4173/tasks",
        "http://127.0.0.1:4173/tasks/CG-AL-E001",
        "http://127.0.0.1:4173/compare?models=sonnet-4-7,gpt-5",
        "http://127.0.0.1:4173/search?q=AL0132",
        "http://127.0.0.1:4173/limitations"
      ],
      "numberOfRuns": 3,
      "startServerCommand": "npm run build && npm run preview",
      "startServerReadyPattern": "(http://[^\\s]+:4173)",
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.90 }],
        "first-contentful-paint": ["error", { "maxNumericValue": 1000 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 1500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.05 }],
        "total-blocking-time": ["error", { "maxNumericValue": 200 }]
      }
    },
    "upload": { "target": "filesystem", "outputDir": "./lhci-reports" }
  }
}
